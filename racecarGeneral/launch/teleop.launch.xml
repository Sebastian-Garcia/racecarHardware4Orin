<!-- -*- mode: XML -*- -->
<launch>

  <arg name="publish_odom_tf" default="true" />
  <group>
    <push-ros-namespace namespace="vesc" />
    <!-- joystick node -->
    <include file="$(find-pkg-share racecar)/launch/joystick.launch.py" ></include>

    <!-- Spawn MUXs -->
    <include file="$(find-pkg-share racecar)/launch/mux2.launch.py" ></include>

    <!-- start electronic speed controller driver -->
    <include file="$(find-pkg-share racecar)/launch/vesc.launch.xml" >
      <arg name="publish_odom_tf" value="$(var publish_odom_tf)" />
    </include> 
  </group>

  <group>
    <!-- start laser scanner -->
    <include file="$(find-pkg-share racecar)/lau<param name="publish_tf" value="$(var publish_wheel_odom)" />nch/sensors.launch.xml" ></include>
  </group>
   

  <group>
    <!-- static transforms, e.g. base_link to imu -->
    <include file="$(find-pkg-share racecar)/launch/static_transforms.launch.xml" /> 
  </group>

</launch>
